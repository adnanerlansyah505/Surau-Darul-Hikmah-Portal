---
import FacilityGalleryClient from './FacilityGalleryClient';
---

<section id="fasilitas" class="section-padding bg-white">
  <div class="container-page">
    <div class="max-w-2xl">
      <h2 class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">
        Fasilitas Surau
      </h2>
      <p class="mt-2 text-sm text-slate-600 sm:text-base">
        Kemudahan yang disediakan untuk keselesaan jamaah dan kelancaran program di Surau Darul
        Hikmah.
      </p>
    </div>

    <FacilityGalleryClient client:visible />
  </div>
</section>

