---
import ManagementGridClient from './ManagementGridClient';
---

<section id="pengurus" class="section-padding bg-white">
  <div class="container-page">
    <div class="max-w-2xl">
      <h2 class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">
        Pengurusan Surau
      </h2>
      <p class="mt-2 text-sm text-slate-600 sm:text-base">
        Struktur pengurusan Surau Darul Hikmah yang menggerakkan program ibadah, ilmu dan
        kebajikan untuk komuniti setempat.
      </p>
    </div>

    <ManagementGridClient client:visible />
  </div>
</section>

