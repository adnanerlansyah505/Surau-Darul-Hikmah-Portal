---
import ProductGridClient from './ProductGridClient';
---

<section id="products" class="section-padding bg-white">
  <div class="container-page">
    <div class="max-w-2xl">
      <h2 class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">
        Produk & Sumbangan Sokongan
      </h2>
      <p class="mt-2 text-sm text-slate-600 sm:text-base">
        Sokong aktiviti Surau Darul Hikmah melalui pembelian produk kecil seperti minuman, makanan
        dan bahan bacaan yang disediakan untuk jamaah.
      </p>
    </div>

    <ProductGridClient client:visible />
  </div>
</section>

